{
  "version": 2,
  "builds": [
    {
      "src": "Web_App/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "Web_App/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "Web_App/app.py"
    }
  ],
  "env": {
    "PYTHONPATH": ".",
    "FLASK_APP": "Web_App/app.py"
  }
}
