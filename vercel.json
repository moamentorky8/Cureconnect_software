{

  "version": 2,

  "builds": [

    {

      "src": "app.py",

      "use": "@vercel/python"

    }

  ],

  "routes": [

    { "src": "/static/(.*)", "dest": "/static/$1" },

    { "src": "/about-us", "dest": "app.py" },

    { "src": "/services", "dest": "app.py" },

    { "src": "/login", "dest": "app.py" },

    { "src": "/register", "dest": "app.py" },

    { "src": "/dashboard", "dest": "app.py" },

    { "src": "/(.*)", "dest": "app.py" }

  ]

}
