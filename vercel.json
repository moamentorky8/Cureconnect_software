{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/about-us.html", "dest": "/about-us" },
    { "src": "/login.html", "dest": "/login" },
    { "src": "/services.html", "dest": "/services" },
    { "src": "/(.*)", "dest": "app.py" }
  ]
}
